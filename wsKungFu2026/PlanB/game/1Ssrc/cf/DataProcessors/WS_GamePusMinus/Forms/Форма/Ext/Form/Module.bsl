&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	URLСервера = "ws://localhost:8080";
	КлючСоединения = Строка(Новый УникальныйИдентификатор());
	Подсказка = "Откройте несколько копий обработки и тяните общий счет в сторону своей команды.";
	СтатусПодключения = "disconnected";
	КомандаИгрока = "-";
	ДействиеКоманды = "";
	Счет = 0;
	ЦелевойСчет = 100;
	ТекстПобеды = "";
	ПобедаАктивна = Ложь;

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)

	ОбновитьСостояниеИнтерфейса();
	ПодключитьсяКИгре();

КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьИгровоеДействие(Команда)

	Если ПобедаАктивна Тогда
		СкрытьПобеду();
	КонецЕсли;

	Соединение = ПолучитьОткрытоеСоединение();
	Если Соединение = Неопределено Тогда
		СтатусПодключения = "disconnected";
		ОбновитьСостояниеИнтерфейса();
		ДобавитьСообщениеВЛог("Нет активного соединения для отправки действия.", Истина);
		Возврат;
	КонецЕсли;

	ДанныеДействия = Новый Структура("type,action", "action", ДействиеКоманды);
	Соединение.ОтправитьСообщение(ЗаписатьСтруктуруВJSONСтроку(ДанныеДействия));

КонецПроцедуры

&НаКлиенте
Процедура ПодключитьсяКИгре()

	Попытка
		СтатусПодключения = "connecting";
		ОбновитьСостояниеИнтерфейса();

		ОбработчикиСокета = Новый ОбработчикиWebSocketКлиентСоединения;
		ОбработчикиСокета.Модуль = ЭтаФорма;
		ОбработчикиСокета.ОбработчикОткрытияСоединения = "ВебСокет_ОбработчикОткрытия";
		ОбработчикиСокета.ОбработчикЗакрытияСоединения = "ВебСокет_ОбработчикЗакрытия";
		ОбработчикиСокета.ОбработчикПолученияСообщения = "ВебСокет_ОбработчикПолученияСообщения";
		ОбработчикиСокета.ОбработчикОшибки = "ВебСокет_ОбработчикОшибки";

		WebSocketКлиентСоединения.ОткрытьСоединение(КлючСоединения, URLСервера, ОбработчикиСокета);
	Исключение
		СтатусПодключения = "disconnected";
		ОбновитьСостояниеИнтерфейса();
		ДобавитьСообщениеВЛог("Ошибка подключения: " + ОписаниеОшибки(), Истина);
	КонецПопытки;

КонецПроцедуры

&НаКлиенте
Процедура ВебСокет_ОбработчикОткрытия(Соединение) Экспорт

	СтатусПодключения = "connected";
	ОбновитьСостояниеИнтерфейса();
	ДобавитьСообщениеВЛог("Соединение установлено.");
	ПринудительноОбновитьПоля(Истина, Ложь, Истина, Ложь);

КонецПроцедуры

&НаКлиенте
Процедура ВебСокет_ОбработчикПолученияСообщения(Соединение, Сообщение) Экспорт

	Данные = ПрочитатьJSONСтрокуБезопасно(Сообщение);
	Если Данные = Неопределено Тогда
		ДобавитьСообщениеВЛог("Получен некорректный JSON от сервера.", Истина);
		Возврат;
	КонецЕсли;

	ТипСообщения = ПолучитьСвойствоСтруктуры(Данные, "type", "");

	Если ТипСообщения = "welcome" Тогда
		КомандаИгрока = ПолучитьСвойствоСтруктуры(Данные, "team", "-");
		ДействиеКоманды = КомандаИгрока;
		Счет = ПолучитьСвойствоСтруктуры(Данные, "score", Счет);
		ЦелевойСчет = ПолучитьСвойствоСтруктуры(Данные, "targetScore", ЦелевойСчет);
		ОбновитьСостояниеИнтерфейса();
		ДобавитьСообщениеВЛог("Вы в команде " + КомандаИгрока + ".");
		ПринудительноОбновитьПоля(Истина, Истина, Истина, Ложь);
		Возврат;
	КонецЕсли;

	Если ТипСообщения = "state" Тогда
		Счет = ПолучитьСвойствоСтруктуры(Данные, "score", Счет);
		ЦелевойСчет = ПолучитьСвойствоСтруктуры(Данные, "targetScore", ЦелевойСчет);
		ПринудительноОбновитьПоля(Ложь, Ложь, Ложь, Ложь);
		Возврат;
	КонецЕсли;

	Если ТипСообщения = "victory" Тогда
		Счет = ПолучитьСвойствоСтруктуры(Данные, "score", Счет);
		ЦелевойСчет = ПолучитьСвойствоСтруктуры(Данные, "targetScore", ЦелевойСчет);
		ПоказатьПобеду(ПолучитьСвойствоСтруктуры(Данные, "message", "Победа!"));
		ДобавитьСообщениеВЛог(ТекстПобеды);
		ПринудительноОбновитьПоля(Ложь, Ложь, Истина, Истина);
		Возврат;
	КонецЕсли;

	Если ТипСообщения = "error" Тогда
		ДобавитьСообщениеВЛог("Ошибка сервера: " + ПолучитьСвойствоСтруктуры(Данные, "message", ""), Истина);
		ПринудительноОбновитьПоля(Ложь, Ложь, Истина, Ложь);
		Возврат;
	КонецЕсли;

	ДобавитьСообщениеВЛог("Неизвестное сообщение: " + Строка(Сообщение), Истина);
	ПринудительноОбновитьПоля(Ложь, Ложь, Истина, Ложь);

КонецПроцедуры

&НаКлиенте
Процедура ВебСокет_ОбработчикОшибки(Соединение, КодОшибки, Описание) Экспорт

	СтатусПодключения = "disconnected";
	ОбновитьСостояниеИнтерфейса();
	ДобавитьСообщениеВЛог("Ошибка WebSocket [" + Строка(КодОшибки) + "]: " + Описание, Истина);
	ПринудительноОбновитьПоля(Истина, Ложь, Истина, Ложь);

КонецПроцедуры

&НаКлиенте
Процедура ВебСокет_ОбработчикЗакрытия(Соединение, КодЗакрытия) Экспорт

	СтатусПодключения = "disconnected";
	ОбновитьСостояниеИнтерфейса();
	ДобавитьСообщениеВЛог("Соединение закрыто. Код: " + Строка(КодЗакрытия) + ".");
	ПринудительноОбновитьПоля(Истина, Ложь, Истина, Ложь);

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСостояниеИнтерфейса()

	Если ПустаяСтрока(ДействиеКоманды) Тогда
		Элементы.КнопкаДействия.Заголовок = "?";
		Элементы.КнопкаДействия.Доступность = Ложь;
	Иначе
		Элементы.КнопкаДействия.Заголовок = ?(ДействиеКоманды = "plus", "+", "-");
		Элементы.КнопкаДействия.Доступность = СтатусПодключения = "connected";
	КонецЕсли;

	Элементы.ТекстПобеды.Видимость = ПобедаАктивна И ЗначениеЗаполнено(ТекстПобеды);

КонецПроцедуры

&НаКлиенте
Процедура ПоказатьПобеду(ТекстСообщения)

	ПобедаАктивна = Истина;
	ТекстПобеды = ТекстСообщения;
	ОбновитьСостояниеИнтерфейса();

КонецПроцедуры

&НаКлиенте
Процедура СкрытьПобеду()

	ПобедаАктивна = Ложь;
	ТекстПобеды = "";
	ОбновитьСостояниеИнтерфейса();

КонецПроцедуры

&НаКлиенте
Процедура ДобавитьСообщениеВЛог(ТекстСообщения, ЭтоОшибка = Ложь)

	НоваяСтрока = Лог.Добавить();
	НоваяСтрока.Время = Формат(ТекущаяДата(), "ДФ=HH:mm:ss");
	НоваяСтрока.Сообщение = ?(ЭтоОшибка, "Ошибка: " + ТекстСообщения, ТекстСообщения);

КонецПроцедуры

&НаКлиенте
Процедура ПринудительноОбновитьПоля(ОбновитьСтатус = Истина, ОбновитьКоманду = Истина, ОбновитьЛог = Ложь, ОбновитьПобеду = Ложь)

	МассивЭлементов = Новый Массив;

	Если ОбновитьСтатус Тогда
		МассивЭлементов.Добавить(Элементы.СтатусПодключения);
	КонецЕсли;

	Если ОбновитьКоманду Тогда
		МассивЭлементов.Добавить(Элементы.КомандаИгрока);
	КонецЕсли;

	МассивЭлементов.Добавить(Элементы.Счет);
	МассивЭлементов.Добавить(Элементы.ЦелевойСчет);

	Если ОбновитьЛог Тогда
		МассивЭлементов.Добавить(Элементы.Лог);
	КонецЕсли;

	Если ОбновитьПобеду Тогда
		МассивЭлементов.Добавить(Элементы.ТекстПобеды);
	КонецЕсли;

	Если МассивЭлементов.Количество() > 0 Тогда
		ЭтаФорма.ОбновитьОтображениеДанных(МассивЭлементов);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Функция ПолучитьОткрытоеСоединение()

	Попытка
		Соединение = WebSocketКлиентСоединения.ПолучитьСоединение(КлючСоединения);
		Если Соединение = Неопределено Тогда
			Возврат Неопределено;
		КонецЕсли;

		Если Соединение.ПолучитьСостояние() <> СостояниеWebSocketСоединения.Открыто Тогда
			Возврат Неопределено;
		КонецЕсли;

		Возврат Соединение;
	Исключение
		Возврат Неопределено;
	КонецПопытки;

КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ЗаписатьСтруктуруВJSONСтроку(Знач Данные)

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Данные);

	Возврат ЗаписьJSON.Закрыть();

КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПрочитатьJSONСтрокуБезопасно(Знач СтрокаJSON)

	Попытка
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
		Возврат ПрочитатьJSON(ЧтениеJSON);
	Исключение
		Возврат Неопределено;
	КонецПопытки;

КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПолучитьСвойствоСтруктуры(Знач Данные, Знач ИмяСвойства, Знач ЗначениеПоУмолчанию = Неопределено)

	ЗначениеСвойства = ЗначениеПоУмолчанию;

	Если ТипЗнч(Данные) = Тип("Структура")
		Или ТипЗнч(Данные) = Тип("ФиксированнаяСтруктура") Тогда
		Если Данные.Свойство(ИмяСвойства, ЗначениеСвойства) Тогда
			Возврат ЗначениеСвойства;
		КонецЕсли;
	КонецЕсли;

	Если ТипЗнч(Данные) = Тип("Соответствие")
		Или ТипЗнч(Данные) = Тип("ФиксированноеСоответствие") Тогда
		ЗначениеСвойства = Данные.Получить(ИмяСвойства);
		Если ЗначениеСвойства <> Неопределено Тогда
			Возврат ЗначениеСвойства;
		КонецЕсли;
	КонецЕсли;

	Возврат ЗначениеПоУмолчанию;

КонецФункции
