
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ЗаголовокФормы = "WebSocket demo";
	ПодзаголовокФормы = "Подключайтесь к WebSocket-серверу, отправляйте сообщения всем клиентам или конкретному clientId и следите за журналом событий.";
	ПодсказкаПолучателя = "Укажите all для рассылки всем или введите clientId из списка справа.";
	WSSАдрес = "ws://localhost:8080";
	СтатусСоединения = "Отключено";
	ИдентификаторКлиента = "-";
	ПолучательСообщения = "all";
	ТекстСообщения = "";
	Подключено = Ложь;
	КлючСоединения = "";
	Если Клиенты.Количество() > 0 Тогда
		Клиенты.Очистить();
	КонецЕсли;
	Если ЖурналСообщений.Количество() > 0 Тогда
		ЖурналСообщений.Очистить();
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)

	ОбновитьСостояниеИнтерфейса();
	ДобавитьСообщениеВЖурнал("Система", "Клиент готов к подключению.");

КонецПроцедуры

&НаКлиенте
Процедура Подключиться(Команда)

	URLСервера = СокрЛП(WSSАдрес);
	Если ПустаяСтрока(URLСервера) Тогда
		ДобавитьСообщениеВЖурнал("Ошибка", "Укажите адрес WebSocket-сервера.");
		Возврат;
	КонецЕсли;

	Если ЕстьАктивноеСоединение() Тогда
		Возврат;
	КонецЕсли;

	Если ПустаяСтрока(КлючСоединения) Тогда
		КлючСоединения = НовыйКлючСоединения();
	КонецЕсли;

	ОбработчикиСокета = Новый ОбработчикиWebSocketКлиентСоединения;
	ОбработчикиСокета.Модуль = ЭтотОбъект;
	ОбработчикиСокета.ОбработчикОткрытияСоединения = "ВебСокетОбработчикОткрытияКлиент";
	ОбработчикиСокета.ОбработчикЗакрытияСоединения = "ВебСокетОбработчикЗакрытияКлиент";
	ОбработчикиСокета.ОбработчикПолученияСообщения = "ВебСокетОбработчикПолученияСообщенияКлиент";
	ОбработчикиСокета.ОбработчикОшибки = "ВебСокетОбработчикОшибкиКлиент";

	ПараметрыСокета = Новый ПараметрыWebSocketКлиентСоединения;

	СтатусСоединения = "Подключение...";
	ОбновитьСостояниеИнтерфейса();
	ДобавитьСообщениеВЖурнал("Система", "Открываем соединение с " + URLСервера + ".");

	Попытка
		WebSocketКлиентСоединения.ОткрытьСоединение(
			КлючСоединения,
			URLСервера,
			ОбработчикиСокета,
			ПараметрыСокета);
	Исключение
		СтатусСоединения = "Ошибка подключения";
		Подключено = Ложь;
		ИдентификаторКлиента = "-";
		ПолучательСообщения = "all";
		КлючСоединения = "";
		Если Клиенты.Количество() > 0 Тогда
			Клиенты.Очистить();
		КонецЕсли;
		ОбновитьСостояниеИнтерфейса();
		ДобавитьСообщениеВЖурнал("Ошибка", ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

&НаКлиенте
Процедура Отключиться(Команда)

	Соединение = ПолучитьТекущееСоединение();
	Если Соединение = Неопределено Тогда
		СброситьСостояниеСоединения();
		ДобавитьСообщениеВЖурнал("Система", "Соединение уже закрыто.");
		Возврат;
	КонецЕсли;

	Попытка
		СтатусСоединения = "Отключение...";
		ОбновитьСостояниеИнтерфейса();
		Соединение.Закрыть();
	Исключение
		ДобавитьСообщениеВЖурнал("Ошибка", ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

&НаКлиенте
Процедура ОтправитьСообщение(Команда)

	Соединение = ПолучитьТекущееСоединение();
	Если Соединение = Неопределено Тогда
		ДобавитьСообщениеВЖурнал("Ошибка", "Нет подключения к серверу.");
		Возврат;
	КонецЕсли;

	Если Соединение.ПолучитьСостояние() <> СостояниеWebSocketСоединения.Открыто Тогда
		ДобавитьСообщениеВЖурнал("Ошибка", "Соединение еще не открыто.");
		Возврат;
	КонецЕсли;

	ТекстДляОтправки = СокрЛП(ТекстСообщения);
	Если ПустаяСтрока(ТекстДляОтправки) Тогда
		ДобавитьСообщениеВЖурнал("Ошибка", "Введите текст сообщения.");
		Возврат;
	КонецЕсли;

	Получатель = СокрЛП(ПолучательСообщения);
	Если ПустаяСтрока(Получатель) Тогда
		Получатель = "all";
	КонецЕсли;

	ПолезнаяНагрузка = Новый Структура;
	ПолезнаяНагрузка.Вставить("type", "message");
	ПолезнаяНагрузка.Вставить("to", Получатель);
	ПолезнаяНагрузка.Вставить("message", ТекстДляОтправки);

	Попытка
		JSONСообщение = ЗаписатьJSONВСтроку(ПолезнаяНагрузка);
		Соединение.ОтправитьСообщение(JSONСообщение);
		ТекстСообщения = "";
	Исключение
		ДобавитьСообщениеВЖурнал("Ошибка", ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

&НаКлиенте
Процедура ВебСокетОбработчикОткрытияКлиент(Соединение) Экспорт

	Подключено = Истина;
	СтатусСоединения = "Подключено";
	ОбновитьСостояниеИнтерфейса();

КонецПроцедуры

&НаКлиенте
Процедура ВебСокетОбработчикПолученияСообщенияКлиент(Соединение, Сообщение) Экспорт

	Если ТипЗнч(Сообщение) <> Тип("Строка") Тогда
		ДобавитьСообщениеВЖурнал("Ошибка", "Получено сообщение в неподдерживаемом формате.");
		Возврат;
	КонецЕсли;

	Попытка
		ПолезнаяНагрузка = ПрочитатьJSONИзСтроки(Сообщение);
		ОбработатьВходящееСообщение(ПолезнаяНагрузка);
	Исключение
		ДобавитьСообщениеВЖурнал("Ошибка", "Получено сообщение в неверном формате JSON.");
	КонецПопытки;

КонецПроцедуры

&НаКлиенте
Процедура ВебСокетОбработчикОшибкиКлиент(Соединение, КодОшибки, Описание) Экспорт

	Подключено = Ложь;
	СтатусСоединения = "Ошибка";
	ИдентификаторКлиента = "-";
	ПолучательСообщения = "all";
	КлючСоединения = "";
	Если Клиенты.Количество() > 0 Тогда
		Клиенты.Очистить();
	КонецЕсли;
	ОбновитьСостояниеИнтерфейса();
	ДобавитьСообщениеВЖурнал("Ошибка", "Код: " + Строка(КодОшибки) + ". " + Описание);

КонецПроцедуры

&НаКлиенте
Процедура ВебСокетОбработчикЗакрытияКлиент(Соединение, КодЗакрытия) Экспорт

	ДобавитьСообщениеВЖурнал("Система", "Соединение закрыто. Код: " + Строка(КодЗакрытия) + ".");
	СброситьСостояниеСоединения();

КонецПроцедуры

&НаКлиенте
Процедура ОбработатьВходящееСообщение(ПолезнаяНагрузка)

	ТипСообщения = ПолучитьЗначениеСтруктуры(ПолезнаяНагрузка, "type", "");

	Если ТипСообщения = "welcome" Тогда
		ИдентификаторКлиента = ПолучитьЗначениеСтруктуры(ПолезнаяНагрузка, "clientId", "-");
		ОбновитьСписокКлиентов(ПолучитьЗначениеСтруктуры(ПолезнаяНагрузка, "clients", Новый Массив));
		ДобавитьСообщениеВЖурнал("Система", "Вы подключены как " + ИдентификаторКлиента + ".");
		Возврат;
	КонецЕсли;

	Если ТипСообщения = "clients" Тогда
		ОбновитьСписокКлиентов(ПолучитьЗначениеСтруктуры(ПолезнаяНагрузка, "clients", Новый Массив));
		Возврат;
	КонецЕсли;

	Если ТипСообщения = "message" Тогда
		Отправитель = ПолучитьЗначениеСтруктуры(ПолезнаяНагрузка, "from", "unknown");
		РежимСообщения = ПолучитьЗначениеСтруктуры(ПолезнаяНагрузка, "mode", "");
		Получатель = ПолучитьЗначениеСтруктуры(ПолезнаяНагрузка, "to", "all");
		Текст = ПолучитьТекстСообщения(ПолезнаяНагрузка);
		ВремяСообщения = ПолучитьЗначениеСтруктуры(ПолезнаяНагрузка, "timestamp", "");
		Если РежимСообщения = "private" Тогда
			ЗаголовокСообщения = "private " + Отправитель + " -> " + Получатель;
		Иначе
			ЗаголовокСообщения = "broadcast from " + Отправитель;
		КонецЕсли;
		Если Не ПустаяСтрока(ВремяСообщения) Тогда
			Текст = Текст + " (" + ВремяСообщения + ")";
		КонецЕсли;
		ДобавитьСообщениеВЖурнал(ЗаголовокСообщения, Текст);
		Возврат;
	КонецЕсли;

	Если ТипСообщения = "system" Тогда
		ДобавитьСообщениеВЖурнал("Система", ПолучитьЗначениеСтруктуры(ПолезнаяНагрузка, "message", ""));
		Возврат;
	КонецЕсли;

	Если ТипСообщения = "error" Тогда
		ТекстОшибки = ПолучитьЗначениеСтруктуры(ПолезнаяНагрузка, "message", "");
		ЦелевойКлиент = ПолучитьЗначениеСтруктуры(ПолезнаяНагрузка, "targetClientId", "");
		Если Не ПустаяСтрока(ЦелевойКлиент) Тогда
			ТекстОшибки = ТекстОшибки + " (" + ЦелевойКлиент + ")";
		КонецЕсли;
		ДобавитьСообщениеВЖурнал("Ошибка", ТекстОшибки);
		Возврат;
	КонецЕсли;

	ДобавитьСообщениеВЖурнал("Система", "Получено сообщение неизвестного типа: " + ТипСообщения + ".");

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСписокКлиентов(МассивКлиентов)

	Если Клиенты.Количество() > 0 Тогда
		Клиенты.Очистить();
	КонецЕсли;
	ТекущийПолучатель = СокрЛП(ПолучательСообщения);
	НайденПолучатель = ТекущийПолучатель = "all" Или ПустаяСтрока(ТекущийПолучатель);

	Для Каждого ИдентификаторКлиентаИзСписка Из МассивКлиентов Цикл
		НоваяСтрока = Клиенты.Добавить();
		НоваяСтрока.Идентификатор = Строка(ИдентификаторКлиентаИзСписка);
		Если НоваяСтрока.Идентификатор = ИдентификаторКлиента Тогда
			НоваяСтрока.Представление = НоваяСтрока.Идентификатор + " (вы)";
		Иначе
			НоваяСтрока.Представление = НоваяСтрока.Идентификатор;
		КонецЕсли;

		Если НоваяСтрока.Идентификатор = ТекущийПолучатель Тогда
			НайденПолучатель = Истина;
		КонецЕсли;
	КонецЦикла;

	Если Не НайденПолучатель Тогда
		ПолучательСообщения = "all";
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ДобавитьСообщениеВЖурнал(Заголовок, Текст)

	НоваяСтрока = ЖурналСообщений.Добавить();
	НоваяСтрока.Время = Формат(ТекущаяДата(), "ДФ=dd.MM.yyyy HH:mm:ss");
	НоваяСтрока.Заголовок = Заголовок;
	НоваяСтрока.Текст = Текст;

КонецПроцедуры

&НаКлиенте
Процедура СброситьСостояниеСоединения()

	Подключено = Ложь;
	СтатусСоединения = "Отключено";
	ИдентификаторКлиента = "-";
	ПолучательСообщения = "all";
	КлючСоединения = "";
	Если Клиенты.Количество() > 0 Тогда
		Клиенты.Очистить();
	КонецЕсли;
	ОбновитьСостояниеИнтерфейса();

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСостояниеИнтерфейса()

	АктивноИлиОткрывается = ЕстьАктивноеСоединение() Или Подключено;
	Элементы.WSSАдрес.Доступность = Не АктивноИлиОткрывается;
	Элементы.ПолучательСообщения.Доступность = Подключено;
	Элементы.ТекстСообщения.Доступность = Подключено;
	Элементы.ОтправитьСообщение.Доступность = Подключено;
	Элементы.Подключиться.Видимость = Не АктивноИлиОткрывается;
	Элементы.Отключиться.Видимость = АктивноИлиОткрывается;

КонецПроцедуры

&НаКлиенте
Функция ЕстьАктивноеСоединение()

	Соединение = ПолучитьТекущееСоединение();
	Если Соединение = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;

	СостояниеСоединения = Соединение.ПолучитьСостояние();
	Возврат СостояниеСоединения = СостояниеWebSocketСоединения.Открывается
		Или СостояниеСоединения = СостояниеWebSocketСоединения.Открыто;

КонецФункции

&НаКлиенте
Функция ПолучитьТекущееСоединение()

	Если ПустаяСтрока(КлючСоединения) Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат WebSocketКлиентСоединения.ПолучитьСоединение(КлючСоединения);

КонецФункции

&НаКлиенте
Функция НовыйКлючСоединения()

	Возврат "WebsocketClient_" + СтрЗаменить(Строка(Новый УникальныйИдентификатор), "-", "");

КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПрочитатьJSONИзСтроки(СтрокаJSON)

	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
	Возврат ПрочитатьJSON(ЧтениеJSON);

КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ЗаписатьJSONВСтроку(ЗначениеДляЗаписи)

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, ЗначениеДляЗаписи);
	Возврат ЗаписьJSON.Закрыть();

КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПолучитьТекстСообщения(ПолезнаяНагрузка)

	ТекстСообщения = ПолучитьЗначениеСтруктуры(ПолезнаяНагрузка, "message", "");
	Если Не ПустаяСтрока(ТекстСообщения) Тогда
		Возврат ТекстСообщения;
	КонецЕсли;

	Возврат ПолучитьЗначениеСтруктуры(ПолезнаяНагрузка, "text", "");

КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПолучитьЗначениеСтруктуры(Источник, ИмяСвойства, ЗначениеПоУмолчанию = Неопределено)

	Если Источник = Неопределено Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;

	Если ТипЗнч(Источник) = Тип("Структура") Или ТипЗнч(Источник) = Тип("ФиксированнаяСтруктура") Тогда
		ЗначениеСвойства = Неопределено;
		Если Источник.Свойство(ИмяСвойства, ЗначениеСвойства) Тогда
			Возврат ЗначениеСвойства;
		КонецЕсли;
	КонецЕсли;

	Возврат ЗначениеПоУмолчанию;

КонецФункции
